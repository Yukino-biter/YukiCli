# YukiCli 环境变量配置示例
# 复制此文件为 .env 并填入你的 API Key
# 支持 GLM / DeepSeek / Kimi / OpenAI 四个 provider，只需配置其中一个

# === GLM（智谱）===
GLM_API_KEY=your-glm-api-key-here
# GLM_MODEL=glm-4-flash
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# === DeepSeek ===
# DEEPSEEK_API_KEY=your-deepseek-api-key-here
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# === Kimi（月之暗面）===
# KIMI_API_KEY=your-kimi-api-key-here
# KIMI_MODEL=moonshot-v1-8k
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# === OpenAI ===
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# === 联网模块（第九期）===
# 搜索 provider 选择：留空自动判断（有 GLM_API_KEY 用 zhipu，有 SERPAPI_KEY 用 serpapi，有 SEARXNG_URL 用 searxng）
# SEARCH_PROVIDER=zhipu

# 智谱 Web Search（与 GLM_API_KEY 共用，无需额外配置；可选切换搜索引擎）
# ZHIPU_SEARCH_ENGINE=search_std
# 可选值：search_std（0.01元/次，默认）/ search_pro / search_pro_sogou / search_pro_quark

# SerpAPI（国际通用，申请：https://serpapi.com/manage-api-key）
# SERPAPI_KEY=your-serpapi-key-here

# SearXNG（自托管免费，docker run --rm -p 8888:8888 searxng/searxng）
# SEARXNG_URL=http://localhost:8888
